# Anthropic API Key - get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# xAI / Grok API Key - get yours at https://console.x.ai
XAI_API_KEY=your_xai_api_key_here

# Optional xAI model overrides for admin-only Grok / Dual engine mode
XAI_ORACLE_MODEL=grok-4-fast-reasoning
XAI_SAFE_MODEL=grok-4-fast-reasoning

# Optional content draft model override (defaults to Claude Haiku)
CONTENT_DRAFT_MODEL=claude-haiku-4-5-20251001

# Server port (default: 3001)
PORT=3001

# Node environment
NODE_ENV=development

# JWT secret - change this to a strong random value in production
JWT_SECRET=hexa-v4-super-secret-key-change-in-production

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/hexadb

# Content API keys for external read-only consumers (format: label:secret,label2:secret2)
CONTENT_API_KEYS=socialmedia:replace_me

# X publishing (optional) - used by the editorial queue for manual/scheduled posting
# Preferred: OAuth 1.0a user-context credentials for the brand account that will publish
X_CONSUMER_KEY=your_x_consumer_key_here
X_CONSUMER_SECRET=your_x_consumer_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here
#
# Optional fallback: OAuth 2.0 user bearer token if you already implemented that flow
X_USER_ACCESS_TOKEN=your_x_user_access_token_here
X_API_BASE_URL=https://api.x.com
X_AUTO_PUBLISH_ENABLED=0
X_AUTO_PUBLISH_INTERVAL_MINUTES=5

# Shadow Mode (admin-only observability for the local tabular validator)
SHADOW_MODE_ENABLED=true
SHADOW_MODE_MODEL_KEY=xgboost_validator_v1
SHADOW_MODE_MODEL_VERSION=1
