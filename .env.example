# Anthropic API Key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server port (default: 3001)
PORT=3001

# Node environment
NODE_ENV=development

# JWT secret — change this to a strong random value in production
JWT_SECRET=hexa-v4-super-secret-key-change-in-production

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/hexadb

# Shadow Mode (admin-only observability for the local tabular validator)
SHADOW_MODE_ENABLED=true
SHADOW_MODE_MODEL_KEY=xgboost_validator_v1
SHADOW_MODE_MODEL_VERSION=1
